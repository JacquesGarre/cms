<form class="d-inline" method="post" action="{{ path('app_attribute_delete', {'id': attribute.id, 'form_id': model.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ attribute.id) }}">
    <button class="btn w-20 p-0 m-0"><i class="material-icons opacity-10">delete</i></button>
</form>
