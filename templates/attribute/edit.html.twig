{% extends 'base.html.twig' %}

{% block title %}Edit Attribute{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent mb-0 pb-0 pt-1 px-0 me-sm-6 me-5">
            <li class="breadcrumb-item text-sm"><a class="opacity-5 text-dark" href="javascript:;">Administration</a></li>
            <li class="breadcrumb-item text-sm"><a class="opacity-5 text-dark" href="{{ path('app_form_index') }}">Models</a></li>
            <li class="breadcrumb-item text-sm"><a class="opacity-5 text-dark" href="{{ path('app_form_edit', {'id': model.id}) }}">{{model.name}}</a></li>
            <li class="breadcrumb-item text-sm text-dark active" aria-current="page">Attribute {{attribute.label.text}}</li>
        </ol>
    </nav>
{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-12">
            <div class="card my-4">
                <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
                    <div class="bg-primary shadow-primary border-radius-lg align-items-center">
                        <h6 class="text-white text-capitalize ps-3  my-0 d-inline-block pt-3  pb-3">
                            Attribute {{attribute.label.text}} 
                        </h6>
                    </div>
                </div>
                <div class="card-body">
                    <div class="nav-wrapper position-relative end-0">
                        <ul class="nav nav-pills nav-fill p-1" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link mb-0 px-0 py-1 active" data-bs-toggle="tab" href="#attributes-tabs-simple" role="tab" aria-controls="attributes" aria-selected="true">
                                    Properties
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link mb-0 px-0 py-1" data-bs-toggle="tab" href="#options-tabs-simple" role="tab" aria-controls="options" aria-selected="false">
                                    Options
                                </a>
                            </li>
                        </ul>
                    </div>
                    <div class="tab-content mt-5">
                        <div class="tab-pane fade show active" id="attributes-tabs-simple" role="tabpanel" aria-labelledby="attributes-tab">
                            <div class="card my-4">
                                <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
                                    <div class="bg-primary shadow-primary border-radius-lg align-items-center">
                                        <h6 class="text-white text-capitalize ps-3  my-0 d-inline-block pt-3  pb-3">
                                            Properties
                                        </h6>
                                    </div>
                                </div>
                                <div class="card-body">
                                    {{ include('attribute/_form.html.twig', {'button_label': 'Update'}) }}
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="options-tabs-simple" role="tabpanel" aria-labelledby="options-tab">
                            <div class="card my-4">
                                <div class="card-header p-0 position-relative mt-n4 mx-3 z-index-2">
                                    <div class="bg-primary shadow-primary border-radius-lg align-items-center">
                                        <h6 class="text-white text-capitalize ps-3  my-0 d-inline-block pt-3  pb-3">
                                            Options
                                        </h6>
                                        <a class="btn btn-icon float-end text-white mt-2 me-2" href="{{ path('app_option_new', {'attribute_id':attribute.id} ) }}">
                                            <span class="btn-inner--icon"><i class="material-icons">add</i></span>
                                        </a>
                                    </div>
                                </div>
                                <div class="card-body">
                                    {{ include('option/index.html.twig') }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}