{% extends 'base.html.twig' %}

{% block title %}FrontOfficeTemplate{% endblock %}

{% block body %}
    <h1>FrontOfficeTemplate</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ front_office_template.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ front_office_template.name }}</td>
            </tr>
            <tr>
                <th>Css</th>
                <td>{{ front_office_template.css }}</td>
            </tr>
            <tr>
                <th>Stylesheets</th>
                <td>{{ front_office_template.stylesheets }}</td>
            </tr>
            <tr>
                <th>Html</th>
                <td>{{ front_office_template.html }}</td>
            </tr>
            <tr>
                <th>Js</th>
                <td>{{ front_office_template.js }}</td>
            </tr>
            <tr>
                <th>Scripts</th>
                <td>{{ front_office_template.scripts }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_front_office_template_index') }}">back to list</a>

    <a href="{{ path('app_front_office_template_edit', {'id': front_office_template.id}) }}">edit</a>

    {{ include('front_office_template/_delete_form.html.twig') }}
{% endblock %}
