<form class="d-inline" method="post" action="{{ path('app_index_delete', {'id': index.id, 'form_id':model.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ index.id) }}">
    <button class="btn p-0 m-0 mb-1 text-white"><i class="material-icons">delete</i></button>
</form>
