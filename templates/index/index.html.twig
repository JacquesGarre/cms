{% block body %}
    <h3>Views</h3>
    <a href="{{ path('app_index_new', {'id':model.id}) }}">Create new</a>

    {% for index in indices %}
        <h4>{{ index.name }}</h4>
        <a href="{{ path('app_index_edit', {'id': index.id, 'form_id':model.id}) }}">edit</a>
        {{ include('index/_delete_form.html.twig') }}
        {{ include('index_column/index.html.twig') }}
        <hr>
    {% else %}
        <p>No records found</p>
    {% endfor %}

    
{% endblock %}
