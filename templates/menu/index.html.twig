    <div class="collapse navbar-collapse  w-auto " id="sidenav-collapse-main">
        <ul class="navbar-nav">
            <li class="nav-item mt-3">
                <h6 class="ps-4 ms-2 text-uppercase text-xs text-dark font-weight-bolder opacity-8">Administration</h6>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark" href="{{ path('app_form_index') }}">
                    <div class="text-dark text-center me-2 d-flex align-items-center justify-content-center">
                        <i class="material-icons opacity-10">category</i>
                    </div>
                    <span class="nav-link-text ms-1">Models</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-dark" href="{{ path('app_menu_item_index') }}">
                    <div class="text-dark text-center me-2 d-flex align-items-center justify-content-center">
