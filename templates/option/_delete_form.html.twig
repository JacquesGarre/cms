<form class="d-inline" method="post" action="{{ path('app_option_delete', {'id': option.id, 'attribute_id':attribute.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ option.id) }}">
    <button class="btn w-10 p-0 m-0"><i class="material-icons opacity-10">delete</i></button>
</form>
