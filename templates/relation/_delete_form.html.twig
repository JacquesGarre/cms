<form class="d-inline" method="post" action="{{ path('app_relation_delete', {'id': relation.id, 'model_id':model.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ relation.id) }}">
    <button class="btn w-10 p-0 m-0"><i class="material-icons opacity-10">delete</i></button>
</form>
