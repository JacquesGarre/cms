{% block body %}

    <h3>Relations</h3>
    <a href="{{ path('app_relation_new', {'model_id':model.id}) }}">Create new</a>

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Mapped by</th>
                <th>Position</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
            {% for relation in relations %}
                <tr>
                    <td>{{ relation.view.name }}</td>
                    <td>{{ relation.mappedBy }}</td>
                    <td>{{ relation.position }}</td>
                    <td>
                        <a href="{{ path('app_relation_edit', {'id': relation.id, 'model_id':model.id}) }}">edit</a>
                        {{ include('relation/_delete_form.html.twig') }}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3">no records found</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    
{% endblock %}
