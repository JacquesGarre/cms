{% block body %}
<div class="table-responsive p-0">
    <table class="table align-items-center justify-content-center mb-0">
        <thead>
            <tr>
                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Position</th>
                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Name</th>
                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Mapped by</th>
                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">actions</th>
            </tr>
        </thead>
        <tbody>
            {% for relation in relations %}
            <tr>
                <td class="align-middle">
                    <span class="text-secondary text-xs font-weight-normal ps-3">
                        {{ relation.position }}
                    </span>
                </td>
                <td class="align-middle">
                    <span class="text-secondary text-xs font-weight-normal ps-3">
                        {{ relation.view.name }}
                    </span>
                </td>
                <td class="align-middle">
                    <span class="text-secondary text-xs font-weight-normal ps-3">
                        {{ relation.mappedBy }}
                    </span>
                </td>
                <td class="align-middle">
                    <a class="text-secondary font-weight-normal ps-3 text-xs btn w-10 p-0 m-0" data-toggle="tooltip" data-original-title="Edit" href="{{ path('app_relation_edit', {'id': relation.id, 'model_id':model.id}) }}">
                        <i class="material-icons opacity-10">edit</i>
                    </a>
                    {{ include('relation/_delete_form.html.twig') }}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="4">
                    {{ include('commons/no_records_found.html.twig') }}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
