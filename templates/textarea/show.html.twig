{% extends 'base.html.twig' %}

{% block title %}Textarea{% endblock %}

{% block body %}
    <h1>Textarea</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ textarea.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ textarea.name }}</td>
            </tr>
            <tr>
                <th>Placeholder</th>
                <td>{{ textarea.placeholder }}</td>
            </tr>
            <tr>
                <th>Disabled</th>
                <td>{{ textarea.disabled ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Readonly</th>
                <td>{{ textarea.readonly ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Required</th>
                <td>{{ textarea.required ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Cols</th>
                <td>{{ textarea.cols }}</td>
            </tr>
            <tr>
                <th>Rowscount</th>
                <td>{{ textarea.rowscount }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_textarea_index') }}">back to list</a>

    <a href="{{ path('app_textarea_edit', {'id': textarea.id}) }}">edit</a>

    {{ include('textarea/_delete_form.html.twig') }}
{% endblock %}
